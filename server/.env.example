# ── Required ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex-string

# ── Optional: Supabase (production DB) ────────────────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
# To activate: rename server/db/supabase.js → server/db/index.js

# ── Optional: Gemini API (animated sponsor icons) ─────────────────────────────
# GEMINI_API_KEY=your-gemini-api-key
# Model used: gemini-2.5-flash-preview-04-17
# Icons cached to server/data/gemini-icons.json after first generation

# ── Optional: Admin ───────────────────────────────────────────────────────────
# ADMIN_KEY=secret-key-for-icon-regeneration-endpoint
BCRYPT_ROUNDS=12
