# DrawNBuy Frontend Environment
# Copy to .env and fill in values

# Backend URL (dev: http://localhost:3001, prod: your Render URL)
VITE_SERVER_URL=http://localhost:3001

# App metadata
VITE_APP_NAME=DrawNBuy
VITE_APP_URL=http://localhost:5173

# Optional: Gemini (for future client-side AI features)
# VITE_GEMINI_API_KEY=your-key
