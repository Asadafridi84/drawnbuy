# DrawnBuy Agent Team — Environment Variables
# Copy this file to your project root .env.local and fill in your values
# NEVER commit .env.local to git!

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Your Anthropic API key — get it at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api-your-key-here

# ── OPTIONAL (enhances Affiliate Agent web research) ──────────────────────────
# Free API key from https://serper.dev (100 free searches/month)
# Without this, the Affiliate Agent will use built-in knowledge instead of live search
SERPER_API_KEY=your-serper-key-here

# ── YOUR EXISTING DRAWNBUY ENV VARS BELOW ────────────────────────────────────
# (Keep all your existing Next.js environment variables here)
# NEXT_PUBLIC_APP_URL=https://drawnbuy.com
# DATABASE_URL=...
# etc.
